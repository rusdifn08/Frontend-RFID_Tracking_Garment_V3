# MJL:  BACKEND_IP=10.5.0.106  PROXY=8000  FRONTEND=5173
# MJL2: BACKEND_IP=10.6.0.99   PROXY=8001  FRONTEND=5174  + VITE_NODE_PROXY_URL
# GCC:  BACKEND_IP=10.5.0.106  PROXY=8002  FRONTEND=5175
